# RightsRadar Environment Variables Template
# Copy this file to .env and fill in your actual values

# OpenAI API Configuration
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
VITE_STRIPE_MONTHLY_PRICE_ID=price_your_monthly_price_id_here
VITE_STRIPE_YEARLY_PRICE_ID=price_your_yearly_price_id_here

# App Configuration
VITE_APP_NAME=RightsRadar
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# Feature Flags
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_RECORDING=true
VITE_ENABLE_OFFLINE_MODE=true

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=your_ga_id_here
VITE_MIXPANEL_TOKEN=your_mixpanel_token_here

# Error Reporting (Optional)
VITE_SENTRY_DSN=your_sentry_dsn_here
